            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Invalid alert payload returns client error\", function () {\r",
                  "    pm.expect([400, 422]).to.include(pm.response.code);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Invalid alert response follows ProblemDetails\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json).to.have.property(\"status\");\r",
                  "    pm.expect(json.status).to.be.within(400, 599);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
