                  "        pm.expect(json.items[0]).to.have.property(\"eventId\");\r",
                  "        pm.expect(json.items[0]).to.have.property(\"eventType\");\r",
                  "        pm.expect(json.items[0]).to.have.property(\"data\");\r",
                  "    }\r",
